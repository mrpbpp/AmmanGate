# AmmanGate Environment Configuration
# Copy this file to .env and update values

# ============================================================================
# CREDENTIALS - CHANGE THESE IN PRODUCTION!
# ============================================================================

# Admin credentials for web dashboard
BG_ADMIN_USER=admin
BG_ADMIN_PASS=admin123
# Or pre-hash the password (optional)
# BG_ADMIN_PASS_HASH=

# Action PIN (used for approving security actions)
# WARNING: Change this in production!
BG_ACTION_PIN=1234

# UI Secret (for session encryption)
# Generate with: openssl rand -base64 32
BG_UI_SECRET=change_me_in_production_use_openssl_rand_base64_32

# ============================================================================
# CORE API CONFIGURATION
# ============================================================================

# Core API address
BG_ADDR=127.0.0.1:8787
CORE_API_URL=http://127.0.0.1:8787

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database type: sqlite or postgres
DB_TYPE=sqlite

# SQLite (default)
BG_DB=./data/bodyguard.db

# PostgreSQL (optional, for high-load scenarios)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=ammangate
# POSTGRES_PASSWORD=change_me
# POSTGRES_DB=ammangate
# POSTGRES_SSLMODE=disable

# ============================================================================
# EXECUTION MODE
# ============================================================================

# Execution mode for security actions:
# - log: Only log actions (default, safe)
# - demo: Show what would happen
# - production: Actually execute firewall rules
BG_EXEC_MODE=log

# ============================================================================
# NETWORK SCANNING
# ============================================================================

# Scan mode: fast, thorough, minimal
BG_SCAN_MODE=fast

# ============================================================================
# WEBSOCKET SECURITY
# ============================================================================

# Allowed origins for WebSocket connections (comma-separated)
# Leave empty for localhost defaults
BG_WS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# MIGRATIONS
# ============================================================================

BG_MIGRATIONS=./migrations

# ============================================================================
# CLAWBOT INTEGRATION
# ============================================================================

# Clawbot API Configuration
# Generate with: [System.Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }) -as [byte[]]) (PowerShell)
# Or with: openssl rand -base64 32
CLAWBOT_API_KEY=change_me_in_production
CLAWBOT_WEBHOOK_SECRET=change_me_in_production

# Clawbot URLs (default values)
CLAWBOT_API_URL=http://127.0.0.1:8080
CLAWBOT_WEBHOOK_URL=http://127.0.0.1:3001/webhook/clawbot

# ============================================================================
# TELEGRAM BOT INTEGRATION (Direct Telegram Bot Mode)
# ============================================================================

# Telegram Bot Token from @BotFather
# Get your bot token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Allowed Telegram User IDs (comma-separated)
# Get your user ID from @userinfobot or @GetMyIdBot
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Gateway Port
CLAW_PORT=3001

# ============================================================================
# DNS SERVER CONFIGURATION (Parental Control)
# ============================================================================

# Enable DNS server for content filtering
BG_DNS_ENABLED=false

# DNS server listen address (port 53 requires admin/root privileges)
BG_DNS_ADDR=:53

# Upstream DNS server for allowed queries
BG_UPSTREAM_DNS=8.8.8.8:53

# ============================================================================
# AI/LLM INTEGRATION (LM Studio)
# ============================================================================

# LM Studio API URL (default: http://localhost:1234/v1)
# Make sure LM Studio is running with "Enable Server" enabled
BG_LM_STUDIO_URL=http://localhost:1234/v1

# Model name in LM Studio
# Example: huihui-ai_-_qwen2.5-coder-7b-instruct-abliterated
BG_LM_STUDIO_MODEL=huihui-ai_-_qwen2.5-coder-7b-instruct-abliterated

# LM Studio API Token (optional, only if authentication is enabled)
# Leave empty if "Require API token" is disabled in LM Studio server settings
# BG_LM_STUDIO_TOKEN=your_token_here

# ============================================================================
# OTHER INTEGRATIONS
# ============================================================================

# mDNS/Hostname (for local network access)
HOSTNAME=bodyguard

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=info
