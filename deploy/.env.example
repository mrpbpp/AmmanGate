# AmmanGate Environment Configuration
# Copy this file to .env and update values

# Action PIN (used for approving security actions)
# WARNING: Change this in production!
ACTION_PIN=1234

# UI Secret (for session encryption)
# Generate with: openssl rand -base64 32
BG_UI_SECRET=change_me_in_production_use_openssl_rand_base64_32

# Core API Configuration
CORE_API_URL=http://127.0.0.1:8787

# Database Path (for non-Docker deployments)
BG_DB=./data/bodyguard.db

# mDNS/Hostname (for local network access)
HOSTNAME=bodyguard

# OpenClaw Integration (optional)
OPENCLAW_ENABLED=false
OPENCLAW_WEBHOOK_URL=
OPENCLAW_API_KEY=

# Logging
LOG_LEVEL=info
