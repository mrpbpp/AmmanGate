# AmmanGate - .gitignore

# Claude Code (local IDE config)
.claude/

# Environment files (IMPORTANT: Never commit .env files with credentials!)
.env
.env.local
.env.*.local
**/.env
!**/.env.example
!**/.env.docker.example

# Database
*.db
*.db-shm
*.db-wal
data/

# Security logs (may contain sensitive info)
suricata-logs/
*.log

# Installers and downloads
*.msi
*.exe
*.zip
*.tar.gz

# Build artifacts
tsconfig.tsbuildinfo
*.tsbuildinfo

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
.next/
out/

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Temporary files
tmp/
temp/
*.tmp
nul

# Docker
.dockerignore

# Coverage
coverage/
*.cover

# OS
Thumbs.db
.DS_Store
