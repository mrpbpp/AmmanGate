# Core API Configuration
CORE_API_URL=http://127.0.0.1:8787

# Gateway Configuration
CLAW_PORT=3001

# Action PIN (must match bodyguard-core BG_ACTION_PIN)
ACTION_PIN=1234

# OpenClaw Configuration (if using OpenClaw integration)
OPENCLAW_WEBHOOK_URL=
OPENCLAW_API_KEY=

# Telegram Bot Configuration (Direct Telegram Bot Mode)
# Get your bot token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Allowed Telegram User IDs (comma-separated)
# Get your user ID from @userinfobot or @GetMyIdBot
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
