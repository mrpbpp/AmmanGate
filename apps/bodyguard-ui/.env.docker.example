# AmmanGate Frontend Docker Environment Variables

# Backend API URL
# In Docker: use container name (bodyguard-core)
# In development: use localhost
NEXT_PUBLIC_BACKENED_API=http://bodyguard-core:8787/v1

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://bodyguard-core:8787/v1/ws

# App Version
NEXT_PUBLIC_APP_VERSION=0.1.0

# Telegram Integration
NEXT_PUBLIC_TELEGRAM_ENABLED=true

# Timezone
TZ=Asia/Jakarta
